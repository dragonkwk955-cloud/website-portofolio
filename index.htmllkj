            <!-- GOOGLE MAPS IFRAME KEDAI KERASA -->
            <div class="map-container">
                <iframe src="https://maps.google.com/maps?q=-6.242437189095004,106.71166928650919&t=&z=15&ie=UTF8&iwloc=&output=embed" width="100%" height="250" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
