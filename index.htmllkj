<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Undangan FIXNIKAH - Dani & Eca</title>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Bebas+Neue&family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --red: #E50914; --red-dark: #b0060f; --gold: #c9a84c;
            --bg: #0a0a0a; --surface: #141414; --surface2: #1e1e1e;
            --text: #FFFFFF; --muted: #a0a0a0; --border: rgba(255,255,255,0.08);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; overflow-x: hidden; }

        /* Typography Khusus Salam & Bismillah */
        .text-salam { font-family: 'Amiri', serif; font-size: 2.5rem; color: #FFFFFF; text-align: center; margin-bottom: 5px; line-height: 1.3; }
        .text-salam-translate { font-family: 'Inter', sans-serif; font-size: 0.75rem; color: var(--muted); text-align: center; margin-bottom: 5px; font-style: italic; }
        .text-bismillah { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.1rem; color: #FFFFFF; text-align: center; margin-bottom: 25px; margin-top: 5px; }

        /* ========== SPLASH SCREEN ========== */
        #splash-screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0; padding: 20px; }
        
        .splash-logo { font-family: 'Bebas Neue', sans-serif; color: var(--red); font-size: 2.2rem; letter-spacing: 5px; margin-bottom: 5px; display: flex; align-items: center; gap: 8px; justify-content: center;} 
        .splash-tagline { color: var(--muted); font-size: 0.8rem; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 30px; }
        
        .splash-profiles { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 15px; }
        .profile-wrap { display: flex; flex-direction: column; align-items: center; cursor: pointer; }
        
        /* Pengaturan Bingkai & Foto */
        .profile-ring { width: 90px; height: 90px; border-radius: 12px; padding: 3px; background: linear-gradient(135deg, var(--red), var(--gold)); }
        .ring-inner { width: 100%; height: 100%; border-radius: 9px; overflow: hidden; background: #222; }
        .profile-ring img { width: 100%; height: 100%; object-fit: cover; display: block; }
        
        .profile-label { font-size: 0.85rem; color: var(--muted); font-weight: 500; }
        .splash-names { font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 4px; color: white; margin-bottom: 8px; margin-top: 15px; }
        .splash-date { color: var(--muted); font-size: 0.85rem; letter-spacing: 2px; margin-bottom: 40px; }
        .btn-open { background: var(--red); border: none; color: #fff; padding: 14px 40px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; cursor: pointer; border-radius: 6px; }

        /* Love Animasi */
        .heart-pulse { font-size: 2rem; animation: pulse 1.5s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }

        /* ========== MAIN CONTENT ========== */
        #main-content { display: none; max-width: 480px; margin: 0 auto; position: relative; padding-bottom: 120px; }
        .floating-action { position: fixed; bottom: 24px; right: 20px; display: flex; flex-direction: column; gap: 12px; z-index: 100; }
        .fab-btn { width: 48px; height: 48px; background: rgba(229,9,20,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: none; color: white; font-size: 1.1rem; cursor: pointer; }

        /* ========== HERO ========== */
        .hero { position: relative; height: 85vh; min-height: 550px; background-color: #111; display: flex; flex-direction: column; justify-content: flex-end; overflow: hidden; }
        .hero-bg { position: absolute; inset: 0; background-image: url('IMG_1345.jpg'); background-size: cover; background-position: center top; filter: brightness(0.85); }
        .hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 60%; background: linear-gradient(to top, #0a0a0a 0%, transparent 100%); z-index: 1; }
        
        /* Teks Melayang Di Awan (Diperbesar) */
        .hero-top-names { position: absolute; top: 40px; left: 0; width: 100%; text-align: center; z-index: 3; text-shadow: 2px 2px 8px rgba(0,0,0,0.9); }
        .name-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; color: var(--gold); margin-bottom: 4px; }
        .name-nickname { font-family: 'Inter', sans-serif; font-size: 1.2rem; font-weight: 700; color: #fff; letter-spacing: 3px; margin-bottom: 12px; }
        .name-amp { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--gold); margin-bottom: 12px; }

        .hero-content { position: relative; z-index: 2; padding: 30px 24px; }
        .hero-date-row { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
        .btn-coming-soon { background: var(--red); color: white; border: none; padding: 6px 14px; border-radius: 4px; font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; }
        .hero-date-text { font-size: 1rem; font-weight: 600; letter-spacing: 1px; }
        .tags-row { display: flex; flex-wrap: wrap; gap: 8px; }
        .tag-pill { background: rgba(255,255,255,0.12); padding: 5px 14px; border-radius: 20px; font-size: 0.78rem; color: #ddd; }

        /* ========== Global Section Styles ========== */
        .section-padding { padding: 36px 24px; }
        .doc-header { display: flex; align-items: center; gap: 10px; color: var(--muted); font-weight: 700; letter-spacing: 3px; font-size: 0.75rem; text-transform: uppercase; margin-bottom: 12px; }
        .doc-header .icon { color: var(--red); font-size: 1rem; }
        .section-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; margin-bottom: 18px; line-height: 1.2; text-align: center; }
        .section-title-left { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; margin-bottom: 18px; line-height: 1.2; text-align: left; }
        .match-row { display: flex; align-items: center; gap: 10px; margin: 14px 0; font-size: 0.88rem; flex-wrap: wrap; }
        .text-green { color: #46d369; font-weight: 700; }
        .box-badge { background: #333; padding: 2px 8px; border-radius: 3px; border: 1px solid #555; font-size: 0.75rem; font-weight: 600; }
        .doc-desc { font-size: 0.95rem; line-height: 1.7; color: #ddd; margin-bottom: 16px; }
        .doc-quote { font-size: 0.9rem; line-height: 1.6; color: var(--muted); font-style: italic; border-left: 2px solid var(--red); padding-left: 14px; margin-top: 10px; }
        .divider { height: 1px; background: var(--border); margin: 0 24px; }

        /* ========== BRIDE, GROOM & GUEST STAR ========== */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
        .person-card { border-radius: 10px; overflow: hidden; background: var(--surface2); }
        .person-img-wrap { width: 100%; aspect-ratio: 3/4; overflow: hidden; background: #222; position: relative; }
        .person-img-wrap img { width: 100%; height: 100%; object-fit: cover; } 
        .person-info { padding: 14px; text-align: center; }
        .person-name { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; margin-bottom: 6px; }
        .person-parents { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

        /* ========== TIMELINE & LOCATION ========== */
        .timeline-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 16px; }
        .timeline-flex { display: flex; gap: 16px; margin-bottom: 16px; }
        .timeline-img { width: 110px; height: 110px; border-radius: 10px; object-fit: cover; object-position: top; background: #333; flex-shrink: 0; }
        .timeline-info { flex: 1; }
        .badge-red { display: inline-block; background: var(--red); color: white; padding: 3px 12px; border-radius: 4px; font-size: 0.78rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 10px; }
        .timeline-date { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: 2px; margin-bottom: 8px; color: white; }
        .chip { display: inline-block; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); padding: 4px 12px; border-radius: 20px; font-size: 0.78rem; margin-right: 6px; margin-bottom: 4px; }
        .address { font-size: 0.88rem; color: var(--muted); line-height: 1.6; margin-bottom: 12px; }

        /* ========== DARK SECTION (NEWS & STORY) ========== */
        .dark-section { background: linear-gradient(180deg, #0a0a1e 0%, #0d0d29 100%); border-top: 1px solid rgba(229,9,20,0.2); padding: 36px 24px; }
        .breaking-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--red); color: white; font-size: 0.7rem; font-weight: 800; letter-spacing: 3px; padding: 5px 12px; border-radius: 3px; margin-bottom: 20px; text-transform: uppercase; }
        .breaking-dot { width: 7px; height: 7px; background: white; border-radius: 50%; animation: blink 1s infinite; }
        .news-main-img { width: 100%; border-radius: 10px; object-fit: cover; object-position: center top; aspect-ratio: 4/3; margin-bottom: 24px; display: block; }
        
        /* Our Love Story */
        .episodes-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; margin: 40px 0 24px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
        .episode { display: flex; gap: 16px; padding: 18px 0; border-bottom: 1px solid var(--border); }
        .episode:last-child { border-bottom: none; }
        .eps-img { width: 90px; height: 115px; border-radius: 8px; object-fit: cover; object-position: top; background: #222; flex-shrink: 0; }
        .eps-body { flex: 1; display: flex; flex-direction: column; justify-content: center; }
        .eps-number { font-size: 0.7rem; color: var(--red); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 6px; }
        .eps-title { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; line-height: 1.3; margin-bottom: 6px; }
        .eps-year { font-size: 0.8rem; color: var(--muted); margin-bottom: 8px; }
        .eps-desc { font-size: 0.82rem; color: #aaa; line-height: 1.5; }

        /* ========== WEDDING GIFT ========== */
        .gift-box { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; text-align: center; margin-bottom: 16px; }
        .bank-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: #0066AE; font-weight: bold; margin-bottom: 8px; }
        .bank-number { font-size: 1.8rem; font-weight: 700; letter-spacing: 3px; color: var(--gold); margin-bottom: 5px; }
        .bank-owner { font-size: 0.9rem; color: var(--muted); margin-bottom: 20px; }
        .btn-copy { background: transparent; border: 1px solid var(--gold); color: var(--gold); padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.85rem; }

        /* ========== GUESTBOOK ========== */
        .form-input { width: 100%; background: #222; border: 1px solid #444; color: white; padding: 14px; border-radius: 8px; margin-bottom: 12px; font-family: 'Inter', sans-serif; font-size: 0.9rem; }
        .form-input:focus { outline: none; border-color: var(--red); }
        .message-list { margin-top: 20px; max-height: 300px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; padding-right: 5px; }
        .message-card { background: var(--surface2); padding: 15px; border-radius: 8px; border-left: 3px solid var(--red); }
        .msg-name { font-weight: 700; font-size: 0.95rem; margin-bottom: 5px; color: var(--gold); }
        .msg-text { font-size: 0.85rem; color: #ddd; line-height: 1.5; }
        .btn-confirm { width: 100%; background: var(--red); color: white; border: none; padding: 16px; font-size: 0.9rem; font-weight: 700; letter-spacing: 2px; border-radius: 8px; cursor: pointer; text-transform: uppercase; margin-top: 12px; transition: background 0.2s, transform 0.2s; }
        .btn-confirm:hover { background: var(--red-dark); transform: translateY(-1px); }

        /* Map Iframe */
        .map-container { width: 100%; border-radius: 12px; overflow: hidden; margin-top: 15px; border: 1px solid var(--border); }
    </style>
</head>
<body>

<audio id="bg-music" loop>
    <!-- PEMANGGILAN LAGU -->
    <source src="lagu.mp3" type="audio/mpeg">
</audio>

<!-- ===== SPLASH SCREEN ===== -->
<div id="splash-screen">
    
    <!-- Teks Assalamualaikum Besar -->
    <div class="text-salam">السَّلاَمُ عَلَيْكُمْ وَرَحْمَةُ اللهِ وَبَرَكَاتُهُ</div>
    
    <!-- Terjemahan Assalamualaikum -->
    <div class="text-salam-translate">assalamu'alaikum warahmatullahi wabarakatuh</div>
    
    <!-- Bismillah di bawah Terjemahan (Putih) -->
    <div class="text-bismillah">Bismillahirrahmanirrahim</div>
    
    <!-- Logo FIXNIKAH dengan Love Biru Diperkecil -->
    <div class="splash-logo">
        <span style="font-size: 1.2rem;">💙</span> 
        FIXNIKAH 
        <span style="font-size: 1.2rem;">💙</span>
    </div>

    <div class="splash-tagline">Who's watching?</div>

    <!-- Profil & Love Merah Tengah -->
    <div class="splash-profiles">
        <!-- FOTO DANI (OPEN INVITATION) -->
        <div class="profile-wrap" onclick="bukaUndangan()">
            <div class="profile-ring">
                <div class="ring-inner">
                    <img src="ss21.jpg" alt="Dani" style="transform: scale(1.5); transform-origin: center 20%;" onerror="this.style.background='#333'">
                </div>
            </div>
        </div>

        <div class="heart-pulse">❤️</div>

        <!-- FOTO ECA (OPEN INVITATION - MENGGUNAKAN 2123.jpeg) -->
        <div class="profile-wrap" onclick="bukaUndangan()">
            <div class="profile-ring">
                <div class="ring-inner">
                    <!-- Penulisan file disesuaikan menjadi .jpeg beserta cadangan .jpg -->
                    <img src="2123.jpeg" alt="Eca" onerror="this.onerror=null; this.src='2123.jpg';">
                </div>
            </div>
        </div>
    </div>

    <!-- Nama User & Logo Sosmed Berbentuk Poligon -->
    <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 30px; width: 100%;">
        <span class="profile-label">@Dani_kurniaa</span>
        
        <div style="display: flex; gap: 6px; background: var(--gold); padding: 5px 12px; clip-path: polygon(10% 0, 90% 0, 100% 50%, 90% 100%, 10% 100%, 0% 50%); align-items: center;">
            <!-- Icon IG -->
            <svg viewBox="0 0 24 24" width="16" height="16" fill="#000"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            <!-- Icon TikTok -->
            <svg viewBox="0 0 24 24" width="16" height="16" fill="#000"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.12-3.44-3.37-3.4-5.74.02-1.89.87-3.72 2.31-4.96 1.46-1.21 3.42-1.74 5.3-1.46.06.39.02.79.03 1.18.01 1.09.02 2.19.03 3.28-.61-.16-1.25-.19-1.87-.06-1.07.2-2 1.04-2.28 2.09-.28.98-.12 2.08.43 2.93.59.95 1.71 1.55 2.83 1.51 1.25-.01 2.37-.8 2.73-2.01.12-.41.17-.84.17-1.27.02-5.46.01-10.92.02-16.38h3.93z"/></svg>
        </div>
        
        <span class="profile-label">@ecahakiki</span>
    </div>

    <div class="splash-names">Dani <span style="color: var(--gold);">&</span> Eca</div>
    <div class="splash-date">24 • MEI • 2026</div>

    <button class="btn-open" onclick="bukaUndangan()">Open Invitation</button>
</div>

<!-- ===== MAIN CONTENT ===== -->
<div id="main-content">

    <div class="floating-action">
        <button class="fab-btn" id="music-btn" onclick="toggleMusic()">🔊</button>
    </div>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        
        <!-- TEKS NAMA DI TENGAH ATAS AWAN (Diperbesar) -->
        <div class="hero-top-names">
            <div class="name-title">Dani Kurnia, S.Pt</div>
            <div class="name-nickname">(DANKUR)</div>
            <div class="name-amp">&</div>
            <div class="name-title">Rissa Nabilla Hakiki, S.M</div>
            <div class="name-nickname">(ECA)</div>
        </div>

        <div class="hero-content">
            <div class="hero-date-row">
                <button class="btn-coming-soon">COMING SOON</button>
                <span class="hero-date-text">24.05.26</span>
            </div>
            <div class="tags-row">
                <span class="tag-pill">#artits</span>
                <span class="tag-pill">#ContenCretor</span>
                <span class="tag-pill">#infulencer</span>
                <span class="tag-pill">#seni</span>
            </div>
        </div>
    </section>

    <div class="divider"></div>

    <!-- INFO DOCUMENTER -->
    <section class="section-padding">
        <div class="doc-header"><span class="icon">▶</span> DOCUMENTER</div>
        <h2 class="section-title-left" style="margin-bottom: 6px; font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; line-height: 1.2; text-align: left;">Dani & Eca:<br>Sebelum Hari H</h2>
        <div class="match-row">
            <span class="text-green">100% match</span>
            <span class="box-badge">SU</span>
            <span>24 Mei 2026</span>
            <span class="box-badge">4K</span>
            <span class="box-badge">HD</span>
        </div>
        <button class="btn-confirm" style="margin-bottom: 24px;">COMING SOON — 24 MEI 2026</button>
        <p class="doc-desc">Setelah Dani dan Eca dipertemukan dalam situasi yang tepat, di mana keduanya telah siap untuk memulai hubungan bersama, tibalah mereka di awal perjalanan baru menuju pernikahan.</p>
        <p class="doc-quote">"Dan di antara tanda-tanda (kebesaran)-Nya ialah Dia menciptakan pasangan-pasangan untukmu dari jenismu sendiri..." — QS. Ar-Rum: 21</p>
    </section>

    <div class="divider"></div>

    <!-- BRIDE & GROOM -->
    <section class="section-padding">
        <h2 class="section-title">Bride & Groom</h2>
        <div class="grid-2">
            <div class="person-card">
                <div class="person-img-wrap">
                    <img src="ss21.jpg" alt="Dani" style="transform: scale(1.5); transform-origin: center 20%;" onerror="this.style.background='#333'">
                </div>
                <div class="person-info">
                    <div class="person-name">Dani</div>
                    <!-- KETERANGAN ANAK DITAMBAHKAN -->
                    <div class="person-parents">Putra dari<br>Bpk. Drs. Harno Suryatna<br>dan Ibu Nani Rustini S.Sos<br>anak ke dua dari empat saudara</div>
                </div>
            </div>
            <div class="person-card">
                <div class="person-img-wrap">
                    <!-- FOTO ECA (DIKEMBALIKAN KE FOTO ASLI SEPERTI PERMINTAAN) -->
                    <img src="WhatsApp Image 2026-04-28 at 10.29.49-fotor-bg-remover-2026042810343.png" alt="Eca" style="transform: scale(1.15); transform-origin: center 80%;" onerror="this.style.background='#333'">
                </div>
                <div class="person-info">
                    <div class="person-name">Eca</div>
                    <!-- KETERANGAN ANAK DITAMBAHKAN -->
                    <div class="person-parents">Putri dari<br>Bpk. Samsudin<br>dan Ibu Riyanti Handayani<br>anak ke dua dari empat bersaudara</div>
                </div>
            </div>
        </div>
    </section>

    <!-- GUEST STAR -->
    <section class="section-padding" style="padding-top: 0;">
        <h2 class="section-title">Menampilkan Guest Star :</h2>
        <div class="grid-2">
            <div class="person-card">
                <div class="person-img-wrap">
                    <img src="rafi.jpg" alt="Rafi Cinoun" onerror="this.onerror=null; this.src='3112.jpg';">
                </div>
                <div class="person-info">
                    <div class="person-name" style="font-size: 1rem;">Rafi Cinoun</div>
                    <div class="person-parents" style="font-size: 0.75rem;">(Aktor Komedian & Presenter)</div>
                </div>
            </div>
            <div class="person-card">
                <div class="person-img-wrap">
                    <img src="T2.jpg.jpeg" alt="T2" onerror="this.onerror=null; this.src='T2.jpg';">
                </div>
                <div class="person-info">
                    <div class="person-name" style="font-size: 1rem;">T2 'Tika & Tiwi'</div>
                    <div class="person-parents" style="font-size: 0.75rem;">(Penyanyi & Aktris)</div>
