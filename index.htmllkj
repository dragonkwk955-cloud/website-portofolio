        </div>
    </section>

    <!-- WEDDING GIFT -->
    <section class="section-padding">
        <div class="doc-header"><span class="icon">🎁</span> WEDDING GIFT</div>
        <h2 class="section-title">Kirim Tanda Kasih</h2>
        <p class="doc-desc">Doa restu Anda merupakan karunia yang sangat berarti bagi kami. Namun, bagi Anda yang ingin memberikan tanda kasih, dapat melalui nomor rekening di bawah ini:</p>
        
        <div class="gift-box">
            <div class="bank-name">BCA</div>
            <div class="bank-number" id="rekening-bca">1081 6128 09</div>
            <div class="bank-owner">a.n. Dani / Eca</div>
            <button class="btn-copy" onclick="var r=document.getElementById('rekening-bca').innerText.replace(/\s/g, ''); navigator.clipboard.writeText(r); alert('Nomor Rekening BCA Berhasil Disalin!');">Salin No. Rekening</button>
        </div>
    </section>

    <div class="divider"></div>

    <!-- KONFIRMASI KEHADIRAN / GUESTBOOK -->
    <section class="section-padding">
        <h2 class="section-title">Konfirmasi Kehadiran</h2>
        <p class="doc-desc">Tinggalkan pesan, doa, dan harapan untuk kedua mempelai.</p>
        
        <div>
            <input type="text" id="nama-pengirim" class="form-input" placeholder="Nama Anda">
            <textarea id="pesan-pengirim" class="form-input" rows="4" placeholder="Tuliskan doa & ucapan..."></textarea>
            <button class="btn-confirm" onclick="kirimUcapan()" style="margin-top: 0;">Kirim Ucapan</button>
        </div>

        <div class="message-list" id="daftar-ucapan">
            <div class="message-card">
                <div class="msg-name">Keluarga Besar</div>
                <div class="msg-text">Selamat menempuh hidup baru untuk Dani & Eca. Semoga menjadi keluarga yang sakinah, mawaddah, warahmah.</div>
            </div>
        </div>
    </section>

</div>

<script>
    function bukaUndangan() {
        document.getElementById('splash-screen').style.display='none'; 
        document.getElementById('main-content').style.display='block'; 
        try { document.getElementById('bg-music').play(); } catch(e) {}
    }

    function toggleMusic() {
        const m = document.getElementById('bg-music');
        const btn = document.getElementById("music-btn");
        if (m.paused) {
            m.play();
            btn.innerHTML = '🔊';
        } else {
            m.pause();
            btn.innerHTML = '🔇';
        }
    }

    function kirimUcapan() {
        const nama = document.getElementById("nama-pengirim").value;
        const pesan = document.getElementById("pesan-pengirim").value;
        
        if(nama.trim() === "" || pesan.trim() === "") {
            alert("Mohon isi nama dan ucapan terlebih dahulu.");
            return;
        }

        const daftarUcapan = document.getElementById("daftar-ucapan");
        const kartuBaru = document.createElement("div");
        kartuBaru.className = "message-card";
        kartuBaru.innerHTML = `<div class="msg-name">${nama}</div><div class="msg-text">${pesan}</div>`;
        
        daftarUcapan.insertBefore(kartuBaru, daftarUcapan.firstChild);
        document.getElementById("nama-pengirim").value = "";
        document.getElementById("pesan-pengirim").value = "";
        alert("Ucapan berhasil dikirim! Terima kasih.");
    }
</script>
</body>
</html>
